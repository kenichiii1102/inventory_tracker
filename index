<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stockroom — Inventory Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#14171A;
    --panel:#1B1F24;
    --panel-2:#20252B;
    --border:#2B3138;
    --text:#E5E7EB;
    --muted:#8B929B;
    --amber:#E8A33D;
    --amber-dim:#8A661F;
    --green:#4F9F6E;
    --red:#D2544B;
    --blue:#5B9BD5;
    --radius:10px;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--text);
    font-family:'Inter',sans-serif;
    padding:2rem 1.5rem 4rem;
  }
  .wrap{max-width:1000px;margin:0 auto;}

  header{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:2rem;
    padding-bottom:1.25rem;
    border-bottom:1px solid var(--border);
  }
  .brand{display:flex;align-items:center;gap:12px;}
  .brand .mark{
    width:36px;height:36px;border-radius:8px;
    background:var(--amber);
    color:#1C1400;
    display:flex;align-items:center;justify-content:center;
    font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:16px;
  }
  h1{
    font-family:'Space Grotesk',sans-serif;
    font-size:22px;font-weight:600;margin:0;letter-spacing:-0.01em;
  }
  .brand p{margin:2px 0 0;color:var(--muted);font-size:13px;}

  .summary{display:flex;gap:12px;}
  .stat{
    background:var(--panel);
    border:1px solid var(--border);
    border-radius:var(--radius);
    padding:10px 16px;
    min-width:90px;
  }
  .stat .n{font-family:'JetBrains Mono',monospace;font-size:20px;font-weight:500;}
  .stat .l{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-top:2px;}

  .layout{display:grid;grid-template-columns:1fr 320px;gap:24px;}
  @media (max-width:800px){.layout{grid-template-columns:1fr;}}

  .panel{
    background:var(--panel);
    border:1px solid var(--border);
    border-radius:var(--radius);
    padding:20px;
  }
  .panel h2{
    font-family:'Space Grotesk',sans-serif;
    font-size:15px;font-weight:600;margin:0 0 14px;
    display:flex;align-items:center;gap:8px;
  }

  form.add-form{display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;}
  form.add-form input{
    flex:1;min-width:120px;
    background:var(--panel-2);
    border:1px solid var(--border);
    color:var(--text);
    padding:9px 12px;
    border-radius:8px;
    font-size:13px;
    font-family:'Inter',sans-serif;
  }
  form.add-form input:focus{outline:none;border-color:var(--amber);}
  form.add-form button{
    background:var(--amber);
    color:#1C1400;
    border:none;
    padding:9px 18px;
    border-radius:8px;
    font-weight:600;
    font-size:13px;
    cursor:pointer;
  }
  form.add-form button:hover{background:#f0ae4f;}

  table{width:100%;border-collapse:collapse;font-size:13px;}
  thead th{
    text-align:left;color:var(--muted);
    font-weight:500;font-size:11px;text-transform:uppercase;letter-spacing:.04em;
    padding:0 10px 10px;border-bottom:1px solid var(--border);
  }
  tbody td{padding:12px 10px;border-bottom:1px solid var(--border);vertical-align:middle;}
  tbody tr:last-child td{border-bottom:none;}
  .item-name{font-weight:500;}
  .sku{color:var(--muted);font-family:'JetBrains Mono',monospace;font-size:12px;}
  .qty{font-family:'JetBrains Mono',monospace;font-size:14px;}
  .qty.low{color:var(--red);}

  .gauge{
    width:60px;height:6px;background:var(--panel-2);
    border-radius:3px;overflow:hidden;margin-top:4px;
  }
  .gauge-fill{height:100%;background:var(--amber);}

  .actions{display:flex;gap:6px;}
  .actions button{
    border:1px solid var(--border);
    background:transparent;
    color:var(--text);
    padding:5px 10px;
    border-radius:6px;
    font-size:11px;
    cursor:pointer;
    font-weight:500;
  }
  .actions button.issue:hover{border-color:var(--red);color:var(--red);}
  .actions button.return:hover{border-color:var(--blue);color:var(--blue);}
  .actions button.receive:hover{border-color:var(--green);color:var(--green);}

  .log{list-style:none;margin:0;padding:0;max-height:520px;overflow-y:auto;}
  .log li{
    padding:10px 0;
    border-bottom:1px solid var(--border);
    font-size:12.5px;
  }
  .log li:last-child{border-bottom:none;}
  .log .row{display:flex;justify-content:space-between;align-items:center;}
  .log .item{font-weight:500;}
  .log .time{color:var(--muted);font-size:11px;font-family:'JetBrains Mono',monospace;}
  .tag{
    font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.03em;
    padding:2px 7px;border-radius:4px;margin-right:6px;
  }
  .tag.issued{background:rgba(210,84,75,0.15);color:var(--red);}
  .tag.returned{background:rgba(91,155,213,0.15);color:var(--blue);}
  .tag.received{background:rgba(79,159,110,0.15);color:var(--green);}
  .empty{color:var(--muted);font-size:13px;text-align:center;padding:20px 0;}

  .modal-bg{
    position:fixed;inset:0;background:rgba(0,0,0,0.6);
    display:none;align-items:center;justify-content:center;z-index:10;
  }
  .modal-bg.open{display:flex;}
  .modal{
    background:var(--panel);border:1px solid var(--border);
    border-radius:var(--radius);padding:22px;width:280px;
  }
  .modal h3{font-family:'Space Grotesk',sans-serif;font-size:15px;margin:0 0 14px;}
  .modal input{
    width:100%;background:var(--panel-2);border:1px solid var(--border);
    color:var(--text);padding:9px 12px;border-radius:8px;font-size:13px;margin-bottom:14px;
    font-family:'JetBrains Mono',monospace;
  }
  .modal-actions{display:flex;gap:8px;justify-content:flex-end;}
  .modal-actions button{
    border:none;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;
  }
  .modal-actions .cancel{background:transparent;color:var(--muted);border:1px solid var(--border);}
  .modal-actions .confirm{background:var(--amber);color:#1C1400;}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="brand">
      <div class="mark">SR</div>
      <div>
        <h1>Stockroom</h1>
        <p>Inventory movement tracker</p>
      </div>
    </div>
    <div class="summary">
      <div class="stat"><div class="n" id="stat-items">0</div><div class="l">Items</div></div>
      <div class="stat"><div class="n" id="stat-onhand">0</div><div class="l">On hand</div></div>
      <div class="stat"><div class="n" id="stat-moves">0</div><div class="l">Movements</div></div>
    </div>
  </header>

  <div class="layout">
    <div class="panel">
      <h2>Items</h2>
      <form class="add-form" id="add-form">
        <input type="text" id="new-name" placeholder="Item name" required>
        <input type="text" id="new-sku" placeholder="SKU" required>
        <input type="number" id="new-qty" placeholder="Starting qty" min="0" value="0" required>
        <button type="submit">Add item</button>
      </form>

      <table>
        <thead>
          <tr>
            <th>Item</th>
            <th>On hand</th>
            <th>Issued</th>
            <th>Returned</th>
            <th>Received</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="item-rows"></tbody>
      </table>
      <div class="empty" id="empty-state" style="display:none;">No items yet — add your first one above.</div>
    </div>

    <div class="panel">
      <h2>Activity log</h2>
      <ul class="log" id="log-list"></ul>
      <div class="empty" id="log-empty">No movements recorded yet.</div>
    </div>
  </div>
</div>

<div class="modal-bg" id="modal-bg">
  <div class="modal">
    <h3 id="modal-title">Issue item</h3>
    <input type="number" id="modal-qty" min="1" value="1" placeholder="Quantity">
    <div class="modal-actions">
      <button class="cancel" id="modal-cancel">Cancel</button>
      <button class="confirm" id="modal-confirm">Confirm</button>
    </div>
  </div>
</div>

<script>
  let items = [
    { id: 1, name: "USB-C Cable 1m", sku: "CBL-UC1", onHand: 42, issued: 0, returned: 0, received: 42 },
    { id: 2, name: "Wireless Mouse", sku: "MSE-WL2", onHand: 15, issued: 5, returned: 0, received: 20 },
    { id: 3, name: "A4 Paper Ream", sku: "PPR-A400", onHand: 3, issued: 27, returned: 0, received: 30 }
  ];
  let log = [];
  let nextId = 4;
  let nextLogId = 1;
  let pendingAction = null;

  const rowsEl = document.getElementById('item-rows');
  const logEl = document.getElementById('log-list');
  const emptyState = document.getElementById('empty-state');
  const logEmpty = document.getElementById('log-empty');
  const modalBg = document.getElementById('modal-bg');
  const modalTitle = document.getElementById('modal-title');
  const modalQty = document.getElementById('modal-qty');

  function fmtTime(){
    return new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
  }

  function render(){
    rowsEl.innerHTML = '';
    emptyState.style.display = items.length ? 'none' : 'block';

    items.forEach(item => {
      const maxRef = Math.max(item.received, item.onHand, 1);
      const pct = Math.min(100, Math.round((item.onHand / maxRef) * 100));
      const low = item.onHand <= 5;

      const tr = document.createElement('tr');
      tr.innerHTML = `
        <td>
          <div class="item-name">${item.name}</div>
          <div class="sku">${item.sku}</div>
        </td>
        <td>
          <span class="qty ${low ? 'low' : ''}">${item.onHand}</span>
          <div class="gauge"><div class="gauge-fill" style="width:${pct}%"></div></div>
        </td>
        <td class="qty">${item.issued}</td>
        <td class="qty">${item.returned}</td>
        <td class="qty">${item.received}</td>
        <td>
          <div class="actions">
            <button class="issue" data-id="${item.id}" data-type="issued">Issue</button>
            <button class="return" data-id="${item.id}" data-type="returned">Return</button>
            <button class="receive" data-id="${item.id}" data-type="received">Receive</button>
          </div>
        </td>
      `;
      rowsEl.appendChild(tr);
    });

    logEmpty.style.display = log.length ? 'none' : 'block';
    logEl.innerHTML = '';
    log.slice(0, 30).forEach(entry => {
      const li = document.createElement('li');
      li.innerHTML = `
        <div class="row">
          <span><span class="tag ${entry.type}">${entry.type}</span><span class="item">${entry.name}</span></span>
          <span class="time">${entry.time}</span>
        </div>
        <div style="color:var(--muted);margin-top:4px;">Qty ${entry.qty} · on hand now ${entry.onHandAfter}</div>
      `;
      logEl.appendChild(li);
    });

    document.getElementById('stat-items').textContent = items.length;
    document.getElementById('stat-onhand').textContent = items.reduce((s,i)=>s+i.onHand,0);
    document.getElementById('stat-moves').textContent = log.length;
  }

  document.getElementById('add-form').addEventListener('submit', e => {
    e.preventDefault();
    const name = document.getElementById('new-name').value.trim();
    const sku = document.getElementById('new-sku').value.trim();
    const qty = parseInt(document.getElementById('new-qty').value, 10) || 0;
    if(!name || !sku) return;
    items.push({ id: nextId++, name, sku, onHand: qty, issued: 0, returned: 0, received: qty });
    e.target.reset();
    document.getElementById('new-qty').value = 0;
    render();
  });

  rowsEl.addEventListener('click', e => {
    const btn = e.target.closest('button[data-id]');
    if(!btn) return;
    const id = parseInt(btn.dataset.id, 10);
    const type = btn.dataset.type;
    pendingAction = { id, type };
    modalTitle.textContent = type === 'issued' ? 'Issue item' : type === 'returned' ? 'Return item' : 'Receive stock';
    modalQty.value = 1;
    modalBg.classList.add('open');
    modalQty.focus();
  });

  document.getElementById('modal-cancel').addEventListener('click', () => {
    modalBg.classList.remove('open');
    pendingAction = null;
  });

  document.getElementById('modal-confirm').addEventListener('click', () => {
    if(!pendingAction) return;
    const qty = parseInt(modalQty.value, 10);
    if(!qty || qty < 1){ modalBg.classList.remove('open'); return; }

    const item = items.find(i => i.id === pendingAction.id);
    if(!item){ modalBg.classList.remove('open'); return; }

    if(pendingAction.type === 'issued'){
      item.issued += qty;
      item.onHand = Math.max(0, item.onHand - qty);
    } else if(pendingAction.type === 'returned'){
      item.returned += qty;
      item.onHand += qty;
    } else if(pendingAction.type === 'received'){
      item.received += qty;
      item.onHand += qty;
    }

    log.unshift({
      id: nextLogId++,
      name: item.name,
      type: pendingAction.type,
      qty,
      onHandAfter: item.onHand,
      time: fmtTime()
    });

    modalBg.classList.remove('open');
    pendingAction = null;
    render();
  });

  modalBg.addEventListener('click', e => {
    if(e.target === modalBg){ modalBg.classList.remove('open'); pendingAction = null; }
  });

  render();
</script>
</body>
</html>
